# Discord Configuration
DISCORD_BOT_TOKEN=MTUyMjE1MjAxMTI1NTEyNDEzOQ.GZbi9s.nv3pLQhqKEKY3KCgSOylF5nHOeOWTT3217dO6A
DISCORD_APPLICATION_ID=1522152011255124139
OWNER_DISCORD_ID=1376784524016619551

# Demo Mode - MUST BE FALSE for production!
# If true, uses simulation and shows DEMO MODE warnings
WOSM_DEMO_MODE=false

# Default Language (ar/en)
DEFAULT_LANGUAGE=ar

# Database
DATABASE_URL=sqlite:///data/wosm.sqlite
BACKUP_DIR=data/backups

# =============================================================================
# OPEN SOURCE ADAPTER - Gift Code Redemption
# =============================================================================
# The adapter uses publicly documented Whiteout Survival API endpoint:
# https://wos-giftcode-api.centurygame.com
#
# This is the OFFICIAL game API used by multiple open source projects.
# No proprietary secrets are required - only CAPTCHA OCR capability.
#
# CAPTCHA SOLVING OPTIONS:
#
# OPTION 1: ONNX Captcha Solver (PRIMARY - Recommended)
#   - Place captcha_model.onnx in models/ directory
#   - Accuracy: ~97.9%
#   - Requires: onnxruntime
#
# OPTION 2: ddddocr (FALLBACK ONLY)
#   - pip install ddddocr
#   - Used if ONNX model is not available
#
# OPTION 3: External CAPTCHA service
#   CAPTCHA_SERVICE_URL=https://your-captcha-service.com
#   CAPTCHA_SERVICE_TOKEN=your_service_token

# Public API Endpoints (no auth required for API access itself)
WOS_GIFT_PUBLIC_ENDPOINT=https://wos-giftcode-api.centurygame.com
WOS_PLAYER_PUBLIC_ENDPOINT=https://wos-giftcode-api.centurygame.com

# External APIs (Optional - for CAPTCHA solving)
# If using external service instead of ONNX/ddddocr
CAPTCHA_SERVICE_URL=
CAPTCHA_SERVICE_TOKEN=

# OCR Service (DEPRECATED - use ONNX or ddddocr)
OCR_SERVICE_URL=

# =============================================================================
# REAL REDEMPTION PROVIDER
# =============================================================================
# Select the provider for real gift code redemption:
# - "WhiteoutProject": Uses centurygame.com API with ONNX captcha solver (RECOMMENDED)
#   * Primary: ONNX model (~97.9% accuracy)
#   * Fallback: ddddocr
# - "Generic": Uses gift_code_client (custom endpoints)
REAL_REDEMPTION_PROVIDER=WhiteoutProject

# =============================================================================
# EXTERNAL REDEMPTION PROVIDER (WhiteoutProject)
# =============================================================================
# Based on: https://github.com/whiteout-project/bot
# API patterns: Dual API support, rate limiting, exponential backoff
#
# Get authorized credentials from your provider.
# NEVER commit credentials to git!
#
# Variables:
# - EXTERNAL_PROVIDER_NAME: Provider name (default: WhiteoutProject)
# - EXTERNAL_PROVIDER_URL: Custom API endpoint (optional)
# - EXTERNAL_PROVIDER_API_KEY: API key from provider (if required)
# - EXTERNAL_PROVIDER_LOGIN_TOKEN: Login token (NEVER COMMIT!)
# - EXTERNAL_PROVIDER_SIGN_SECRET: Custom sign salt (optional)
# - EXTERNAL_PROVIDER_COOKIE: Cookie for auth (NEVER COMMIT!)
# - EXTERNAL_PROVIDER_SESSION: Session ID (NEVER COMMIT!)
EXTERNAL_PROVIDER_NAME=WhiteoutProject
EXTERNAL_PROVIDER_URL=
EXTERNAL_PROVIDER_API_KEY=
EXTERNAL_PROVIDER_LOGIN_TOKEN=
EXTERNAL_PROVIDER_SIGN_SECRET=
EXTERNAL_PROVIDER_COOKIE=
EXTERNAL_PROVIDER_SESSION=

# Legacy API URLs (still supported but deprecated)
WOS_API_BASE_URL=
GIFT_CODE_API_BASE_URL=

# Theme Colors (Hex without #)
THEME_COLOR_PRIMARY=0x3498db
THEME_COLOR_SUCCESS=0x2ecc71
THEME_COLOR_WARNING=0xf39c12
THEME_COLOR_ERROR=0xe74c3c
THEME_COLOR_INFO=0x1abc9c

# Logging
LOG_LEVEL=INFO
DEBUG=false
