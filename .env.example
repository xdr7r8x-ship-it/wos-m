# WOS-M Environment Configuration
# © MANSOUR — WOS-M. All rights reserved.
# DO NOT commit this file with real values!

# Discord Configuration
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_APPLICATION_ID=your_application_id_here
OWNER_DISCORD_ID=your_discord_user_id

# Default Language (ar/en)
DEFAULT_LANGUAGE=ar

# Database
DATABASE_URL=sqlite:///data/wosm.sqlite
BACKUP_DIR=data/backups

# External APIs
# WOS API - Real game API (REQUIRED for production)
WOS_API_BASE_URL=https://api.whiteoutsurvival.com

# Gift Code API - Real redemption API (REQUIRED for production)
GIFT_CODE_API_BASE_URL=https://api.whiteoutsurvival.com/gift

# Captcha Service (REQUIRED for production)
CAPTCHA_SERVICE_URL=https://captcha.service.com
CAPTCHA_SERVICE_TOKEN=your_captcha_token_here

# OCR Service (Optional)
OCR_SERVICE_URL=https://ocr.example.com

# Demo Mode - MUST BE FALSE for production!
# If true, uses simulation and shows DEMO MODE warnings
WOSM_DEMO_MODE=false

# Theme Colors (Hex without #)
THEME_COLOR_PRIMARY=0x3498db
THEME_COLOR_SUCCESS=0x2ecc71
THEME_COLOR_WARNING=0xf39c12
THEME_COLOR_ERROR=0xe74c3c
THEME_COLOR_INFO=0x1abc9c

# Logging
LOG_LEVEL=INFO
DEBUG=false
