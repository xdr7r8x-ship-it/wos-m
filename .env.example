# WOS-M Environment Configuration Template
# © MANSOUR — WOS-M. All rights reserved.
# Copy this file to .env and fill in your values

# Discord Configuration
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_APPLICATION_ID=your_application_id_here
OWNER_DISCORD_ID=your_discord_user_id_here

# Demo Mode
WOSM_DEMO_MODE=false

# Language
DEFAULT_LANGUAGE=ar

# Database
DATABASE_URL=sqlite:///data/wosm.sqlite
BACKUP_DIR=data/backups

# Gift Code API
GIFT_CODE_API_BASE_URL=https://wos-giftcode-api.centurygame.com
WOS_API_BASE_URL=https://api.centurygame.com
WOS_GIFT_PUBLIC_ENDPOINT=https://wos-giftcode-api.centurygame.com
WOS_PLAYER_PUBLIC_ENDPOINT=https://wos-giftcode-api.centurygame.com

# OCR Service (local ddddocr or external service)
# Options:
#   - local-ddddocr : Use local OCR (requires: pip install ddddocr)
#   - https://your-captcha-service.com : External captcha service
CAPTCHA_SERVICE_URL=local-ddddocr
CAPTCHA_SERVICE_TOKEN=local
OCR_SERVICE_URL=local-ddddocr

# Redemption Provider
REAL_REDEMPTION_PROVIDER=WhiteoutProject
EXTERNAL_PROVIDER_NAME=WhiteoutProject

# Colors
THEME_COLOR_PRIMARY=0x3498db
THEME_COLOR_SUCCESS=0x2ecc71
THEME_COLOR_WARNING=0xf39c12
THEME_COLOR_ERROR=0xe74c3c
THEME_COLOR_INFO=0x1abc9c

# Logging
LOG_LEVEL=INFO
DEBUG=false
